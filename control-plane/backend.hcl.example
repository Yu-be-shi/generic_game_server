# control-plane 用 Terraform backend 設定
#
# 使い方:
#   1. このファイルを backend.hcl という名前でコピー
#   2. bucket の値を `terraform output -raw tf_state_bucket_name` の出力で置き換え
#   3. terraform init -migrate-state -backend-config=backend.hcl
#
# backend.hcl は .gitignore 済みのためコミットされない（アカウント情報を含むため）

bucket = "yubeshi-game-server-terraform-state"
key    = "control-plane/terraform.tfstate"
region = "ap-northeast-1"
