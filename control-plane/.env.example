# control-plane 用環境変数テンプレート
# このファイルを .env という名前でコピーして値を記入する
# .env は .gitignore 済みのためコミットされない

# Discord Developer Portal → アプリ → General Information → PUBLIC KEY
export TF_VAR_discord_public_key="ここに64文字の公開鍵"

# Discord で 開発者モードON → 自分のアイコン右クリック → IDをコピー
export TF_VAR_discord_allowed_user_ids='["あなたのDiscordユーザーID"]'

# 複数人に許可する場合:
# export TF_VAR_discord_allowed_user_ids='["123456789012345678", "987654321098765432"]'
